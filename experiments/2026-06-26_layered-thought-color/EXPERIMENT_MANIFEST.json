{
    "name":  "thought-color-code-v0.1",
    "created":  "2026-06-26",
    "status":  "draft",
    "scope":  "isolated experiment",
    "summary":  "Base2024 is treated as a coarse color, with small modifier channels layered outside it.",
    "principles":  [
                       "Keep 2024 base collisions as useful sharing, not as a bug to erase.",
                       "Treat extra bits as separate semantic channels.",
                       "Do not train on the packed 19-bit value as the only label.",
                       "Keep this outside semantic-packet.v1 until measured."
                   ],
    "layout":  {
                   "base_id":  {
                                   "bits":  11,
                                   "valid_values":  2024,
                                   "reserved_values":  24
                               },
                   "stance":  {
                                  "bits":  3,
                                  "valid_values":  8
                              },
                   "operation":  {
                                     "bits":  3,
                                     "valid_values":  8
                                 },
                   "intensity":  {
                                     "bits":  2,
                                     "valid_values":  4
                                 }
               },
