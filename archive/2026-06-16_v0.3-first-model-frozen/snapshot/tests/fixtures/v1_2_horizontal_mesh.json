{
  "schema_version": "horizontal-unit-mesh.v1",
  "decision_method": "integrated_score_times_action_weight",
  "normalization": "divide_all_votes_when_peak_exceeds_one",
  "control_axis_priority": ["ask", "verify", "plan", "summarize", "creative", "caution"],
  "fallback_axis_priority": ["reply", "explain"],
  "axis_to_mode": {
    "ask": "clarify",
    "verify": "verify",
    "plan": "build",
    "summarize": "summarize",
    "creative": "explore",
    "caution": "verify",
    "reply": "respond",
    "explain": "explain"
  },
  "candidate_fields": [
    "axis",
    "mode",
    "vote",
    "priority_group",
    "priority_rank",
    "selected",
    "reason"
  ]
}
