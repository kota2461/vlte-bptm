# --- Python ---
__pycache__/
*.py[cod]
*.pyc.*
.pytest_cache/
pytest-cache-files-*/
*.egg-info/

# setuptools build-staging output (regenerable; not source)
build/lib/
/dist/

# Tracked exception: legacy baseline bytecode is the source of truth for
# baseline_snapshot.py recovery (S2). See build/recovery_assets/README.md.
!build/recovery_assets/
!build/recovery_assets/baseline_legacy_cpython310.pyc

# --- runtime data / models produced at runtime ---
data/*.db
data/*.db-*
build/pattern_router_model.json

# --- logs and server scratch output ---
*.log
*.stderr.log
*.stdout.log

# --- archive: keep only the frozen first-model snapshot ---
archive/*
!archive/2026-06-16_v0.3-first-model-frozen/
!archive/2026-06-16_v0.3-first-model-frozen/**
# strip noise back out of the kept snapshot (explicit paths override the re-include above)
archive/2026-06-16_v0.3-first-model-frozen/**/*.log
archive/2026-06-16_v0.3-first-model-frozen/**/__pycache__/
archive/2026-06-16_v0.3-first-model-frozen/**/*.py[cod]

# --- local experiment snapshots / copied worktrees ---
# These are large local snapshots used for side experiments. Keep them on disk,
# but do not let them drown the main repository status.
experiments/2026-06-19_current-model-no-backup/
experiments/2026-06-19_role-split-detectors/

# --- local debate run logs ---
# Canonical V6 fixtures/reports live in build/v6_* and tests/fixtures/v6_*.
# Raw LM Studio/router debate runs are local evidence and can be regenerated.
build/router_debate_*.json
